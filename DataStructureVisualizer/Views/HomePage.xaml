<Page x:Class="DataStructureVisualizer.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="277*"/>
            <RowDefinition Height="109*"/>
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">

            <TextBlock Text="Data Structure Visualizer" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,0,0,10" TextAlignment="Center"/>

            <Button x:Name="StackBtn" Content="Stack" FontSize="22" Width="300" Height="60" Margin="0,10" Background="DarkOrange" Foreground="White" Click="StackBtn_Click"/>

            <Button x:Name="QueueBtn" Content="Queue" FontSize="22" Width="300" Height="60" Margin="0,10" Background="DarkOrange" Foreground="White" Click="QueueBtn_Click"/>

            <Button Content="Linked List" FontSize="22" Width="300" Height="60" Margin="0,10" Background="Gray" Foreground="DarkGray" IsEnabled="False"/>

            <Button Content="Binary Search Tree (BST)" FontSize="22" Width="300" Height="60" Margin="0,10" Background="Gray" Foreground="DarkGray" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Page>